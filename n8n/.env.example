# Copy this file to .env. Never commit the real .env file.
N8N_ENCRYPTION_KEY=replace-with-a-long-random-value
GENERIC_TIMEZONE=Asia/Kolkata
N8N_RUNNERS_ENABLED=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
DB_SQLITE_POOL_SIZE=2
TARGET_WORKSPACE_ID=copy-your-workspace-id-from-Supabase-Table-Editor
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
AUTOMATION_INGEST_SECRET=replace-with-a-long-random-value
